# =============================================================================
# ZeroPath Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# cp .env.example .env
# =============================================================================

# --- Required ---

# OpenAI API key for LLM-powered vulnerability analysis
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# --- Security (change these in production) ---

# Secret key for JWT token signing (use a random 32+ char string)
SECRET_KEY=change-me-to-a-random-secret-key

# Secret key for CSRF token generation (use a different random string)
CSRF_SECRET=change-me-to-a-different-secret

# --- Optional ---

# LLM model to use (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# Max concurrent LLM API calls per scan (default: 5)
# LLM_MAX_CONCURRENCY=5

# Max file size to analyze in KB (default: 50)
# MAX_FILE_SIZE_KB=50

# Max number of Python files to analyze per scan (default: 200)
# MAX_FILES_PER_SCAN=200

# Database URL (default: SQLite in project root)
# DATABASE_URL=sqlite+aiosqlite:///./zeropath.db

# CORS allowed origins (comma-separated, default: http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost

# Directory for temporary repo clones (default: ./cloned_repos)
# CLONED_REPOS_DIR=./cloned_repos
