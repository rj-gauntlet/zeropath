# ===========================================
# ZeroPath LLM Security Scanner - Environment
# ===========================================

# --- Required ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Backend (optional; defaults shown) ---
# SECRET_KEY=change-me-in-production-use-a-random-string
# DATABASE_URL=sqlite+aiosqlite:///./zeropath.db
# CORS_ORIGINS=http://localhost:5173
# CSRF_SECRET=change-me-in-production-use-a-random-string

# --- LLM Configuration (optional; defaults shown) ---
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_CONCURRENCY=5

# --- Git/Scan Limits (optional; defaults shown) ---
# MAX_FILE_SIZE_KB=50
# MAX_FILES_PER_SCAN=200

# --- Frontend (optional; defaults to http://localhost:8000) ---
# VITE_API_URL=http://localhost:8000
